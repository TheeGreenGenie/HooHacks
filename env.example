# Environment variables for Wild West Finance Cowboy App (FAKE VALUES)
# Copy to .env for local use and replace with real secrets.

# App
APP_ENV=development
PROJECT_NAME=HooHacks Wild West Finance
DOMAIN=localhost

# MongoDB Atlas
MONGO_DATABASE_URI=mongodb+srv://fake_user:fake_pass@fakecluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE=app

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=FAKE_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=FAKE_AUTH0_CLIENT_SECRET
AUTH0_AUDIENCE=https://api.yourapp.com

# AI Providers
GEMINI_API_KEY=FAKE_GEMINI_API_KEY
SNOWFLAKE_API_KEY=FAKE_SNOWFLAKE_API_KEY

# OCR (Google Cloud Vision)
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\fake-service-account.json

# Voice (ElevenLabs)
ELEVENLABS_API_KEY=FAKE_ELEVENLABS_API_KEY

# Merchant Inventories API
MERCHANT_INVENTORIES_API_KEY=FAKE_MERCHANT_INVENTORIES_API_KEY

# Payments (placeholder)
ENABLE_PAYMENTS=false
